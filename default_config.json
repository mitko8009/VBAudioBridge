{
    "vm": {
        "KIND_ID": "potato",
        "DEFAULT_STRIPS_TO_UPDATE": [7],
        "DEFAULT_BUSES_TO_UPDATE": [],
        "AVAILABLE_STRIPS": [0, 5, 6, 7],
        "AVAILABLE_BUSES": [0, 1],
        "MAX_VOLUME_DB": 0.0,
        "MIN_VOLUME_DB": -60.0,
        "ROUND_TO_INTEGER": false,
        "MATCH_MUTE_STATE": true,
        "DISABLE_MULTI_SELECT_STRIPS": true,
        "DISABLE_MULTI_SELECT_BUSES": false
    },
    "PAUSE_MEDIA_ON_MUTE": true,
    "MUTE_FOR_NEXT_TRACK": false,
    "logging": {
        "version": 1,
        "disable_existing_loggers": false,
        "formatters": {
            "simple": {
                "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
            }
        },
        "handlers": {
            "console": {
                "class": "logging.StreamHandler",
                "level": "DEBUG",
                "formatter": "simple",
                "stream": "ext://sys.stdout"
            },
            "file": {
                "class": "logging.FileHandler",
                "level": "INFO",
                "formatter": "simple",
                "filename": "app.log",
                "mode": "w"
            }
        },
        "root": {
            "level": "DEBUG",
            "handlers": [
                "console",
                "file"
            ]
        }
    }
}